<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.context.remote-cli</string>

    <key>Program</key>
    <string>/Users/John/.local/bin/remote-cli/start-remote-cli.sh</string>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/John/.local/bin/remote-cli/logs/launchd-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/John/.local/bin/remote-cli/logs/launchd-stderr.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:/Users/John/.local/bin</string>
    </dict>
</dict>
</plist>
